# Blizzard API (required for all commands)
BLIZZARD_CLIENT_ID="your-client-id-here"
BLIZZARD_CLIENT_SECRET="your-client-secret-here"

# Discord (DISCORD_PUBLIC_KEY required for 'serve')
DISCORD_PUBLIC_KEY="your-discord-public-key-here"
# optional, 'register' only
# DISCORD_BOT_TOKEN="your-discord-bot-token-here"
# optional, 'register' only
# DISCORD_APP_ID="your-discord-app-id-here"
# optional, 'register' only
# DISCORD_GUILD_ID="your-discord-guild-id-here"

# WoW (WOW_REALM and WOW_GUILD required for 'update')
# optional, default: eu
# WOW_REGION="eu"
# WOW_REALM="your-realm-slug-here"
# WOW_GUILD="your-guild-slug-here"

# Server (all optional, defaults shown)
# local CLI only: groster serve
# GROSTER_HOST="127.0.0.1"
# local CLI port, and published host port in Docker Compose
# GROSTER_PORT="5000"
# GROSTER_DATA_PATH="./data"
# GROSTER_LOG_DIR="./logs"

# set to "json" in container
# GROSTER_LOG_FORMAT="text"
